{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "my-docs",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "my-docs",
			// Run `wrangler d1 create my-docs` and paste the real ID here for deploy
			"database_id": "local"
		}
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "my-docs-media"
		}
	]
}
