---
import Icon from '../Icon.astro';
import type { Icons } from '../Icons';
import { blockMarkdownToHtml } from './inline-markdown';

export interface Props {
  node: {
    id?: string;
    title?: string;
    icon?: string;
    color?: string;
    content?: string;
  };
}

const { node } = Astro.props;
const { title, icon, color, content } = node;

const colorVariables: Record<string, { border: string; bg: string }> = {
  purple: { border: 'var(--sl-color-purple)', bg: 'var(--sl-color-purple-low)' },
  orange: { border: 'var(--sl-color-orange)', bg: 'var(--sl-color-orange-low)' },
  green: { border: 'var(--sl-color-green)', bg: 'var(--sl-color-green-low)' },
  red: { border: 'var(--sl-color-red)', bg: 'var(--sl-color-red-low)' },
  blue: { border: 'var(--sl-color-blue)', bg: 'var(--sl-color-blue-low)' },
};

const cardStyle = color && colorVariables[color]
  ? `--sl-card-border: ${colorVariables[color].border}; --sl-card-bg: ${colorVariables[color].bg};`
  : '';
---

<article class="emdash-block-wrap card sl-flex" style={cardStyle} data-block-type="star-lite.card" data-block-props={JSON.stringify(node)}>
  <p class="title sl-flex">
    {icon && <Icon name={icon as keyof typeof Icons} class="icon" size="1.333em" />}
    {title && <span data-sl-edit="title" set:html={title} />}
  </p>
  {content && <div class="body" data-sl-edit="content" set:html={blockMarkdownToHtml(content)} />}
  <slot />
</article>

<style>
  .card {
    --sl-card-border: var(--sl-color-purple);
    --sl-card-bg: var(--sl-color-purple-low);
    border: 1px solid var(--sl-color-gray-5);
    background-color: var(--sl-color-black);
    padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
    flex-direction: column;
    gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
  }
  .card:nth-child(4n + 1) { --sl-card-border: var(--sl-color-orange); --sl-card-bg: var(--sl-color-orange-low); }
  .card:nth-child(4n + 3) { --sl-card-border: var(--sl-color-green); --sl-card-bg: var(--sl-color-green-low); }
  .card:nth-child(4n + 4) { --sl-card-border: var(--sl-color-red); --sl-card-bg: var(--sl-color-red-low); }
  .card:nth-child(4n + 5) { --sl-card-border: var(--sl-color-blue); --sl-card-bg: var(--sl-color-blue-low); }
  .title {
    font-weight: 600;
    font-size: var(--sl-text-h4);
    color: var(--sl-color-white);
    line-height: var(--sl-line-height-headings);
    gap: 1rem;
    align-items: center;
  }
  .card .icon {
    border: 1px solid var(--sl-card-border);
    background-color: var(--sl-card-bg);
    padding: 0.2em;
    border-radius: 0.25rem;
    flex-shrink: 0;
  }
  .card .body {
    margin: 0;
    font-size: clamp(var(--sl-text-sm), calc(0.5rem + 1vw), var(--sl-text-body));
  }
</style>
