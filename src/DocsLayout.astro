---
/**
 * Main docs layout — replaces Starlight's Page.astro + PageFrame.astro.
 * Three-column layout: sidebar, content, table of contents.
 */
import "./style/props.css";
import "./style/reset.css";
import "./style/markdown.css";
import "./style/asides.css";
import "./style/util.css";

import DocsSidebar from "./Sidebar.astro";
import HeaderActions from "./HeaderActions.astro";
import { buildSidebar, markCurrent, type SidebarConfig, type SidebarEntry } from "./types";
import Icon from "./Icon.astro";
import Search from "./Search.astro";
import ThemeSelect from "./ThemeSelect.astro";

export interface Props {
	title: string;
	toc?: Array<{ depth: number; slug: string; text: string }>;
	slug?: string;
	sidebar: SidebarConfig[];
	siteTitle?: string;
	splash?: boolean;
}

const { title, toc = [], slug, sidebar: sidebarConfig, siteTitle = 'Buylist Software Documentation', splash = false } = Astro.props;
const currentPath = Astro.url.pathname;
const activeSidebar = markCurrent(buildSidebar(sidebarConfig), currentPath);
const isSplash = splash;
const showToc = !isSplash && toc.length > 0;
---

<html
	lang="en"
	dir="ltr"
	data-theme="dark"
	data-has-sidebar
	data-has-toc={showToc ? "" : undefined}
	data-splash={isSplash ? "" : undefined}
>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} | {siteTitle}</title>
		<link rel="shortcut icon" href="/favicon.svg" type="image/svg+xml" />
		<script src="https://cdn.shopify.com/shopifycloud/polaris.js"></script>
		<script is:inline>
			(function() {
				var stored = typeof localStorage !== 'undefined' && localStorage.getItem('starlight-theme');
				var theme = stored === 'dark' || stored === 'light' ? stored
					: window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
				document.documentElement.dataset.theme = theme;
			})();
		</script>
		<style>
			html:not([data-has-toc]) { --sl-mobile-toc-height: 0rem; }
			html:not([data-has-sidebar]) { --sl-content-width: 67.5rem; }
			html { scroll-padding-top: calc(1.5rem + var(--sl-nav-height) + var(--sl-mobile-toc-height)); }
			main { padding: var(--sl-main-pad); }
			@media (min-width: 50em) {
				[data-has-sidebar] { --sl-content-inline-start: var(--sl-sidebar-width); }
			}
			@media (min-width: 72em) {
				html { scroll-padding-top: calc(1.5rem + var(--sl-nav-height)); }
			}
		</style>
	</head>
	<body>
		<div class="page sl-flex">
			<!-- Header -->
			<header class="header">
				<div class="header-inner sl-flex">
					<div class="title-wrapper sl-flex">
						<a href="/" class="site-title sl-flex" translate="no">
							<span>{siteTitle}</span>
						</a>
					</div>
					<div class="sl-flex print:hidden">
						<Search />
					</div>
					<div class="sl-hidden md:sl-flex print:hidden right-group">
						<div class="sl-flex social-icons">
							<HeaderActions />
						</div>
						<ThemeSelect />
					</div>
				</div>
			</header>

			<!-- Sidebar -->
			<nav class="sidebar print:hidden" aria-label="Main navigation">
				<starlight-menu-button class="print:hidden">
					<button aria-expanded="false" aria-label="Menu" aria-controls="docs-sidebar" class="sl-flex md:sl-hidden menu-toggle">
						<Icon name="bars" class="open-menu" />
						<Icon name="close" class="close-menu" />
					</button>
				</starlight-menu-button>
				<div id="docs-sidebar" class="sidebar-pane">
					<div class="sidebar-content sl-flex">
						<DocsSidebar sublist={activeSidebar} />
					</div>
				</div>
			</nav>

			<!-- Main content -->
			<div class="main-frame">
				{/* Mobile TOC */}
				{showToc && (
					<div class="lg:sl-hidden">
						<mobile-starlight-toc data-min-h="2" data-max-h="3">
							<nav aria-labelledby="on-this-page--mobile">
								<details id="mobile-toc">
									<summary id="on-this-page--mobile" class="sl-flex">
										<span class="mobile-toc-toggle sl-flex">
											On this page
											<Icon name="right-caret" class="mobile-toc-caret" size="1rem" />
										</span>
										<span class="mobile-toc-display-current" />
									</summary>
									<div class="mobile-toc-dropdown">
										<ul class="mobile-toc-list">
											{toc.map(h => (
												<li style={`--depth: ${h.depth - 2}`}>
													<a href={`#${h.slug}`}><span>{h.text}</span></a>
												</li>
											))}
										</ul>
									</div>
								</details>
							</nav>
						</mobile-starlight-toc>
					</div>
				)}

				<div class="lg:sl-flex content-wrapper">
					{/* Desktop TOC */}
					{showToc && (
						<aside class="right-sidebar-container print:hidden">
							<div class="right-sidebar">
								<div class="right-sidebar-panel sl-hidden lg:sl-block">
									<div class="sl-container">
										<starlight-toc data-min-h="2" data-max-h="3">
											<nav aria-labelledby="on-this-page">
												<h2 id="on-this-page">On this page</h2>
												<ul>
													{toc.map(h => (
														<li style={`--depth: ${h.depth - 2}`}>
															<a href={`#${h.slug}`}><span>{h.text}</span></a>
														</li>
													))}
												</ul>
											</nav>
										</starlight-toc>
									</div>
								</div>
							</div>
						</aside>
					)}
					<div class="main-pane">
						<main>
							{isSplash ? (
								<div class="content-panel splash-panel">
									<div class="sl-container splash-container">
										<slot />
									</div>
								</div>
							) : (
								<>
									<div class="content-panel">
										<div class="sl-container">
											<h1 id="_top">{title}</h1>
										</div>
									</div>
									<div class="content-panel">
										<div class="sl-container">
											<slot />
										</div>
									</div>
								</>
							)}
						</main>
					</div>
				</div>
			</div>
		</div>

		<script>
			class StarlightMenuButton extends HTMLElement {
				btn = this.querySelector('button')!;
				constructor() {
					super();
					this.btn.addEventListener('click', () => this.toggleExpanded());
					this.closest('nav')?.addEventListener('keyup', (e) => {
						if ((e as KeyboardEvent).code === 'Escape') {
							this.setExpanded(false);
							this.btn.focus();
						}
					});
				}
				setExpanded(expanded: boolean) {
					this.setAttribute('aria-expanded', String(expanded));
					document.body.toggleAttribute('data-mobile-menu-expanded', expanded);
				}
				toggleExpanded() {
					this.setExpanded(this.getAttribute('aria-expanded') !== 'true');
				}
			}
			customElements.define('starlight-menu-button', StarlightMenuButton);

			// TOC highlight current heading
			class StarlightTOC extends HTMLElement {
				_current = this.querySelector<HTMLAnchorElement>('a[aria-current="true"]');
				minH = parseInt(this.dataset.minH || '2', 10);
				maxH = parseInt(this.dataset.maxH || '3', 10);

				set current(link: HTMLAnchorElement) {
					if (link === this._current) return;
					if (this._current) this._current.removeAttribute('aria-current');
					link.setAttribute('aria-current', 'true');
					this._current = link;
				}

				constructor() {
					super();
					const onIdle = window.requestIdleCallback || ((cb: () => void) => setTimeout(cb, 1));
					onIdle(() => this.init());
				}

				init() {
					const links = [...this.querySelectorAll('a')];
					const selector = `h1#_top,:where(${Array.from({ length: 1 + this.maxH - this.minH }, (_, i) => `h${this.minH + i}`).join()})[id]`;
					const isHeading = (el: Element): el is HTMLHeadingElement => el.matches(selector);

					const getElementHeading = (el: Element | null): HTMLHeadingElement | null => {
						if (!el) return null;
						const origin = el;
						while (el) {
							if (el.matches('.sl-markdown-content, main > *')) return document.getElementById('_top') as HTMLHeadingElement;
							if (isHeading(el)) return el;
							const child = el.querySelector<HTMLHeadingElement>(selector);
							if (child) return child;
							el = el.previousElementSibling;
							while (el?.lastElementChild) el = el.lastElementChild;
							const h = getElementHeading(el);
							if (h) return h;
						}
						return getElementHeading(origin.parentElement);
					};

					const setCurrent: IntersectionObserverCallback = (entries) => {
						for (const { isIntersecting, target } of entries) {
							if (!isIntersecting) continue;
							const heading = getElementHeading(target);
							if (!heading) continue;
							const link = links.find(l => l.hash === '#' + encodeURIComponent(heading.id));
							if (link) { this.current = link; break; }
						}
					};

					const toObserve = document.querySelectorAll(
						[`main :where(${selector})`, `main :where(${selector}) ~ *:not(:has(${selector}))`, `main .sl-markdown-content > *:not(:has(${selector}))`, `main > *:not(:has(${selector}))`].join()
					);

					const navH = document.querySelector('header')?.getBoundingClientRect().height || 0;
					const mobileH = this.querySelector('summary')?.getBoundingClientRect().height || 0;
					const top = navH + mobileH + 32;
					const bottom = top + 53;
					const height = document.documentElement.clientHeight;

					const observer = new IntersectionObserver(setCurrent, { rootMargin: `-${top}px 0% ${bottom - height}px` });
					toObserve.forEach(el => observer.observe(el));
				}
			}
			customElements.define('starlight-toc', StarlightTOC);

			class MobileStarlightTOC extends StarlightTOC {
				override set current(link: HTMLAnchorElement) {
					super.current = link;
					const display = this.querySelector('.mobile-toc-display-current') as HTMLSpanElement;
					if (display) display.textContent = link.textContent;
				}
				constructor() {
					super();
					// Initialize with first link text
					const firstLink = this.querySelector('a');
					const display = this.querySelector('.mobile-toc-display-current') as HTMLSpanElement;
					if (firstLink && display) display.textContent = firstLink.textContent;
					const details = this.querySelector('details');
					if (!details) return;
					const close = () => { details.open = false; };
					details.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
					window.addEventListener('click', e => { if (!details.contains(e.target as Node)) close(); });
					window.addEventListener('keydown', e => {
						if (e.key === 'Escape' && details.open) {
							const hadFocus = details.contains(document.activeElement);
							close();
							if (hadFocus) details.querySelector('summary')?.focus();
						}
					});
				}
			}
			customElements.define('mobile-starlight-toc', MobileStarlightTOC);
		</script>

		<style>
			.page { flex-direction: column; min-height: 100vh; }

			/* Header */
			.header {
				z-index: var(--sl-z-index-navbar);
				position: fixed;
				inset-inline-start: 0;
				inset-block-start: 0;
				width: 100%;
				height: var(--sl-nav-height);
				border-bottom: 1px solid var(--sl-color-hairline-shade);
				padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
				background-color: var(--sl-color-bg-nav);
			}
			:global([data-has-sidebar]) .header {
				padding-inline-end: calc(var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size));
			}
			.header-inner {
				display: flex;
				gap: var(--sl-nav-gap);
				justify-content: space-between;
				align-items: center;
				height: 100%;
			}
			.site-title {
				align-items: center;
				gap: var(--sl-nav-gap);
				font-size: var(--sl-text-h4);
				font-weight: 600;
				color: var(--sl-color-text-accent);
				text-decoration: none;
				white-space: nowrap;
				min-width: 0;
			}
			.site-title span { overflow: hidden; }
			.title-wrapper { overflow: clip; padding: 0.25rem; margin: -0.25rem; min-width: 0; }
			.right-group, .social-icons { gap: 1rem; align-items: center; }
			.social-icons::after {
				content: '';
				height: 2rem;
				border-inline-end: 1px solid var(--sl-color-gray-5);
			}
			@media (min-width: 50rem) {
				:global([data-has-sidebar]) .header { padding-inline-end: var(--sl-nav-pad-x); }
				:global(:root[data-has-sidebar]) { --__sidebar-pad: calc(2 * var(--sl-nav-pad-x)); }
				:global(:root:not([data-has-toc])) { --__toc-width: 0rem; }
				.header-inner {
					--__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
					--__main-column-fr: calc(
						(100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
						(2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
						var(--sl-content-width)) / 2
					);
					display: grid;
					grid-template-columns:
						minmax(calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))), auto)
						1fr
						auto;
					align-content: center;
				}
			}

			.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }

			/* Mobile TOC */
			mobile-starlight-toc nav {
				position: fixed;
				z-index: var(--sl-z-index-toc);
				top: calc(var(--sl-nav-height) - 1px);
				inset-inline: 0;
				border-top: 1px solid var(--sl-color-gray-5);
				background-color: var(--sl-color-bg-nav);
			}
			@media (min-width: 50rem) {
				mobile-starlight-toc nav {
					inset-inline-start: var(--sl-content-inline-start, 0);
				}
			}
			mobile-starlight-toc summary {
				gap: 0.5rem;
				align-items: center;
				height: var(--sl-mobile-toc-height);
				border-bottom: 1px solid var(--sl-color-hairline-shade);
				padding: 0.5rem 1rem;
				font-size: var(--sl-text-xs);
				outline-offset: var(--sl-outline-offset-inside);
			}
			mobile-starlight-toc summary::marker,
			mobile-starlight-toc summary::-webkit-details-marker { display: none; }
			.mobile-toc-toggle {
				flex-shrink: 0;
				gap: 1rem;
				align-items: center;
				justify-content: space-between;
				border: 1px solid var(--sl-color-gray-5);
				border-radius: 0.5rem;
				padding-block: 0.5rem;
				padding-inline-start: 0.75rem;
				padding-inline-end: 0.5rem;
				line-height: 1;
				background-color: var(--sl-color-black);
				user-select: none;
				cursor: pointer;
			}
			details[open] .mobile-toc-toggle { color: var(--sl-color-white); border-color: var(--sl-color-accent); }
			details .mobile-toc-toggle:hover { color: var(--sl-color-white); border-color: var(--sl-color-gray-2); }
			details[open] :global(.mobile-toc-caret) { transform: rotateZ(90deg); }
			.mobile-toc-display-current {
				white-space: nowrap;
				text-overflow: ellipsis;
				overflow: hidden;
				color: var(--sl-color-white);
			}
			.mobile-toc-dropdown {
				--border-top: 1px;
				margin-top: calc(-1 * var(--border-top));
				border: var(--border-top) solid var(--sl-color-gray-6);
				border-top-color: var(--sl-color-hairline-shade);
				max-height: calc(85vh - var(--sl-nav-height) - var(--sl-mobile-toc-height));
				overflow-y: auto;
				background-color: var(--sl-color-black);
				box-shadow: var(--sl-shadow-md);
				overscroll-behavior: contain;
			}
			.mobile-toc-list { padding: 0; list-style: none; }
			.mobile-toc-list a {
				--pad-inline: 1rem;
				display: flex;
				justify-content: space-between;
				gap: var(--pad-inline);
				border-top: 1px solid var(--sl-color-gray-6);
				border-radius: 0;
				padding-block: 0.5rem;
				padding-inline: calc(1rem * var(--depth, 0) + var(--pad-inline)) var(--pad-inline);
				color: var(--sl-color-text);
				font-size: var(--sl-text-sm);
				text-decoration: none;
				outline-offset: var(--sl-outline-offset-inside);
			}
			.mobile-toc-list li:first-child > a { border-top: 0; }
			.mobile-toc-list a[aria-current='true'],
			.mobile-toc-list a[aria-current='true']:hover { color: var(--sl-color-white); }
			.mobile-toc-list a[aria-current='true']::after {
				content: '';
				width: 1rem;
				background-color: var(--sl-color-text-accent);
				-webkit-mask-image: url('data:image/svg+xml;base64,');
				mask-image: url('data:image/svg+xml;base64,');
				-webkit-mask-repeat: no-repeat;
				mask-repeat: no-repeat;
				flex-shrink: 0;
			}

			/* Sidebar */
			.sidebar-pane {
				visibility: var(--sl-sidebar-visibility, hidden);
				position: fixed;
				z-index: var(--sl-z-index-menu);
				inset-block: var(--sl-nav-height) 0;
				inset-inline-start: 0;
				width: 100%;
				background-color: var(--sl-color-black);
				overflow-y: auto;
			}
			:global([aria-expanded='true']) ~ .sidebar-pane { --sl-sidebar-visibility: visible; }
			.sidebar-content {
				height: 100%;
				min-height: max-content;
				padding: 1rem var(--sl-sidebar-pad-x) 0;
				flex-direction: column;
				gap: 1rem;
			}
			@media (min-width: 50rem) {
				.sidebar-pane {
					--sl-sidebar-visibility: visible;
					width: var(--sl-sidebar-width);
					background-color: var(--sl-color-bg-sidebar);
					border-inline-end: 1px solid var(--sl-color-hairline-shade);
				}
			}

			/* Mobile menu toggle */
			.menu-toggle {
				position: fixed;
				top: calc((var(--sl-nav-height) - var(--sl-menu-button-size)) / 2);
				inset-inline-end: var(--sl-nav-pad-x);
				z-index: var(--sl-z-index-navbar);
				border: 0;
				border-radius: 50%;
				width: var(--sl-menu-button-size);
				height: var(--sl-menu-button-size);
				padding: 0.5rem;
				background-color: var(--sl-color-white);
				color: var(--sl-color-black);
				box-shadow: var(--sl-shadow-md);
				cursor: pointer;
			}
			[aria-expanded='true'] .menu-toggle { background-color: var(--sl-color-gray-2); box-shadow: none; }
			[aria-expanded='true'] .menu-toggle .open-menu { display: none; }
			:not([aria-expanded='true']) .menu-toggle .close-menu { display: none; }

			/* Main frame */
			.main-frame {
				padding-top: calc(var(--sl-nav-height) + var(--sl-mobile-toc-height));
				padding-inline-start: var(--sl-content-inline-start);
			}

			/* Content area */
			.main-pane { isolation: isolate; flex: 1; min-width: 0; width: 100%; }
			.content-panel { padding: 1.5rem calc(var(--sl-content-pad-x) / 2); }
			.content-panel + .content-panel { border-top: 1px solid var(--sl-color-hairline); }
			.content-panel .sl-container { max-width: 100%; width: 100%; }
			.content-panel .sl-container > :global(* + *) { margin-top: 1.5rem; }
			@media (min-width: 72rem) {
				.content-wrapper {
					display: flex;
					gap: 2rem;
					width: 100%;
					max-width: 100%;
					padding-right: 2rem;
				}
				.main-pane { order: 1; flex: 1; width: 100%; max-width: none; margin: 0; }
				:global([data-has-sidebar][data-has-toc]) .main-pane {
					--sl-content-margin-inline: 0;
					margin: 0;
					max-width: none;
					width: 100%;
				}
				.content-panel .sl-container {
					margin-inline-start: auto;
					margin-inline-end: 0;
					max-width: calc(100% - 2rem);
				}
			}

			/* Right sidebar (TOC) */
			.right-sidebar-container { display: none; }
			@media (min-width: 72rem) {
				.right-sidebar-container { display: block; order: 2; position: relative; width: 16rem; flex-shrink: 0; }
			}
			.right-sidebar {
				position: fixed;
				top: 0;
				border-inline-start: 1px solid var(--sl-color-hairline);
				padding-top: var(--sl-nav-height);
				width: 16rem;
				height: 100vh;
				overflow-x: hidden;
				overflow-y: auto;
				scrollbar-width: thin;
			}
			.right-sidebar-panel { padding: 1rem var(--sl-sidebar-pad-x); }
			.right-sidebar-panel h2 {
				color: var(--sl-color-white);
				font-size: var(--sl-text-h5);
				font-weight: 600;
				line-height: var(--sl-line-height-headings);
				margin-bottom: 0.5rem;
			}
			.right-sidebar-panel a {
				display: block;
				font-size: var(--sl-text-xs);
				text-decoration: none;
				color: var(--sl-color-gray-3);
				overflow-wrap: anywhere;
				padding: 0.15rem 0;
			}
			.right-sidebar-panel a:hover { color: var(--sl-color-white); }
			.right-sidebar-panel ul { list-style: none; padding: 0; }
			.right-sidebar-panel li { padding-inline-start: calc(var(--depth, 0) * 1rem); }

			/* Mobile overrides */
			:global([data-mobile-menu-expanded]) { overflow: hidden; }
			@media (min-width: 50rem) {
				:global([data-mobile-menu-expanded]) { overflow: auto; }
			}

			h1 {
				font-size: var(--sl-text-h1);
				line-height: var(--sl-line-height-headings);
				font-weight: 600;
				color: var(--sl-color-white);
			}

			/* Splash template — hide sidebar, widen content, no TOC */
			:global(html[data-splash]) .sidebar,
			:global(html[data-splash]) .menu-toggle { display: none; }
			:global(html[data-splash]) .main-frame { padding-inline-start: 0; }
			:global(html[data-splash]) .header { padding-inline-end: var(--sl-nav-pad-x); }
			.splash-panel { padding-block: clamp(1rem, calc(0.5rem + 4vmin), 2rem); }
			.splash-container {
				max-width: min(100%, 90rem);
				margin-inline: auto;
			}
			.splash-body > :global(* + *) { margin-top: 1.5rem; }
		</style>

		<script>
			function syncEditableState() {
				const toolbar = document.getElementById('emdash-toolbar');
				const editMode = toolbar?.dataset.editMode === 'true';
				document.querySelectorAll('[data-editable="true"]').forEach(el => {
					if (editMode) {
						el.setAttribute('contenteditable', 'true');
					} else {
						el.removeAttribute('contenteditable');
					}
				});
				document.querySelectorAll('.emdash-block-wrap').forEach(wrap => {
					const w = wrap as HTMLElement;
					if (editMode) {
						w.style.position = 'relative';
						if (!w.querySelector('.emdash-block-edit')) {
							const btn = document.createElement('button');
							btn.className = 'emdash-block-edit';
							btn.type = 'button';
							btn.textContent = 'Edit';
							w.insertBefore(btn, w.firstChild);
						}
					} else {
						w.querySelector('.emdash-block-edit')?.remove();
					}
				});
			}
			syncEditableState();
			const toolbar = document.getElementById('emdash-toolbar');
			if (toolbar) {
				new MutationObserver(syncEditableState).observe(toolbar, { attributes: true, attributeFilter: ['data-edit-mode'] });
			}
			document.addEventListener('astro:page-load', syncEditableState);
		</script>

		<style is:global>
			.emdash-block-edit {
				display: none;
				position: absolute;
				top: 0.25rem;
				right: 0.25rem;
				z-index: 10;
				padding: 0.125rem 0.5rem;
				font-size: var(--sl-text-xs);
				background: #3b82f6;
				color: white;
				border: none;
				border-radius: 0.25rem;
				cursor: pointer;
			}
			.emdash-block-edit:hover { background: #2563eb; }
			.emdash-block-wrap:hover > .emdash-block-edit { display: block; }
		</style>
	</body>
</html>
